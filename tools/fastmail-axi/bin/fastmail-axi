async function cmdDelete(args) {
  var emailId = args[1];
  if (!emailId) die('missing email ID');

  if (!hasFlag(args, '--yes')) {
    var confirmed = await confirmPrompt('Delete email ' + emailId + '?');
    if (!confirmed) die('cancelled');
  }

  var result = await mcpCallTool('delete_email', { email_id: emailId });
  ok(result || { deleted: emailId });
}

async function cmdMove(args) {
  var emailId = args[1];
  var mailbox = args[2];
  if (!emailId) die('missing email ID');
  if (!mailbox) die('missing target mailbox');

  var result = await mcpCallTool('move_email', { email_id: emailId, mailbox: mailbox });
  ok(result);
}

async function cmdThread(args) {
  var threadId = args[1];
  if (!threadId) die('missing thread ID');

  var result = await mcpCallTool('get_thread', { thread_id: threadId });
  var messages = result.messages || result.emails || result || [];
  if (!Array.isArray(messages)) messages = [messages];

  console.log('ok: true');
  console.log('thread[' + messages.length + ']{id,from,subject,date}:');
  for (var i = 0; i < messages.length; i++) {
    console.log('  ' + formatEmailSummary(messages[i]));
  }
}

async function cmdReply(args) {
  var emailId = args[1];
  var body = args[2];
  if (!emailId) die('missing email ID');
  if (!body) die('missing reply body');

  var params = { email_id: emailId, body: body };
  var replyAll = hasFlag(args, '--all');
  if (replyAll) params.reply_all = true;

  var result = await mcpCallTool('reply_email', params);
  ok(result);
}

async function cmdAccount(args) {
  try {
    var result = await mcpCallTool('get_account_summary', {});
    ok(result);
  } catch (e) {
    ok({ status: 'error', error: e.message, url: FASTMAIL_URL });
    process.exit(1);
  }
}

async function cmdIdentities(args) {
  var result = await mcpCallTool('list_identities', {});
  var identities = result.identities || result || [];
  if (!Array.isArray(identities)) identities = [identities];

  console.log('ok: true');
  console.log('identities[' + identities.length + ']{id,name,email}:');
  for (var i = 0; i < identities.length; i++) {
    var idn = identities[i];
    console.log('  ' + [
      idn.id || '?',
      idn.name || '(no name)',
      idn.email || '?'
    ].join(','));
  }
}

async function cmdLabels(args) {
  var subcmd = args[1];
  var emailId = args[2];

  if (subcmd === 'list') {
    if (!emailId) die('missing email ID');
    var result = await mcpCallTool('list_labels', { email_id: emailId });
    ok(result);
  } else if (subcmd === 'add') {
    if (!emailId) die('missing email ID');
    var labels = args.slice(3);
    if (labels.length === 0) die('missing labels');
    var result = await mcpCallTool('add_labels', { email_id: emailId, labels: labels });
    ok(result);
  } else if (subcmd === 'remove') {
    if (!emailId) die('missing email ID');
    var labels2 = args.slice(3);
    if (labels2.length === 0) die('missing labels');
    var result2 = await mcpCallTool('remove_labels', { email_id: emailId, labels: labels2 });
    ok(result2);
  } else {
    die('unknown labels subcommand: ' + subcmd + ' (use add, remove, or list)');
  }
}

async function cmdBulk(args) {
  var subcmd = args[1];
  var mailbox = args[2];
  if (!subcmd) die('missing bulk subcommand (delete, read, move, pin)');
  if (!mailbox) die('missing mailbox');

  var params = { mailbox: mailbox };
  var ids = consumeFlag(args, '--ids');
  var query = consumeFlag(args, '--query');
  if (ids) params.ids = ids.split(',').map(function(s) { return s.trim(); });
  if (query) params.query = query;

  if (subcmd === 'delete') {
    if (!hasFlag(args, '--yes')) {
      var confirmed = await confirmPrompt('Bulk delete emails in mailbox ' + mailbox + '?');
      if (!confirmed) die('cancelled');
    }
    var result = await mcpCallTool('bulk_delete', params);
    ok(result);
  } else if (subcmd === 'read') {
    var result2 = await mcpCallTool('bulk_mark_read', params);
    ok(result2);
  } else if (subcmd === 'move') {
    var target = args[3];
    if (!target) die('missing target mailbox for move');
    params.target = target;
    var result3 = await mcpCallTool('bulk_move', params);
    ok(result3);
  } else if (subcmd === 'pin') {
    var result4 = await mcpCallTool('bulk_pin', params);
    ok(result4);
  } else {
    die('unknown bulk subcommand: ' + subcmd + ' (use delete, read, move, or pin)');
  }
}

async function cmdAdvancedSearch(args) {
  var query = args[1];
  if (!query) die('missing JMAP query (JSON string)');

  var queryObj;
  try {
    queryObj = JSON.parse(query);
  } catch (e) {
    die('invalid JSON query: ' + e.message);
  }

  var result = await mcpCallTool('advanced_search', { query: queryObj });
  var emails = result.emails || result.messages || result || [];
  if (!Array.isArray(emails)) emails = [emails];

  console.log('ok: true');
  console.log('advanced-search[' + emails.length + ']{id,from,subject,date}:');
  for (var i = 0; i < emails.length; i++) {
    console.log('  ' + formatEmailSummary(emails[i]));
  }
}

async function cmdCall(args) {
  var toolName = args[1];
  if (!toolName) die('missing tool name');

  var params = {};

  // Check for --json flag
  var jsonArg = flagVal(args, '--json');
  if (jsonArg) {
    try {
      params = JSON.parse(jsonArg);
    } catch (e) {
      die('invalid JSON args: ' + e.message);
    }
  } else {
    // Parse remaining args as --key value pairs
    for (var i = 2; i < args.length; i++) {
      if (args[i].startsWith('--')) {
        var key = args[i].slice(2);
        if (i + 1 < args.length && !args[i + 1].startsWith('--')) {
          params[key] = args[i + 1];
          i++;
        } else {
          params[key] = true;
        }
      }
    }
  }

  var result = await mcpCallTool(toolName, params);
  ok(result);
}

async function cmdStatus(args) {
  try {
    await ensureInitialized();
    var toolCount = _toolSchemas ? Object.keys(_toolSchemas).length : 0;
    ok({
      status: 'ok',
      tools: toolCount,
      url: FASTMAIL_URL,
      protocolVersion: (_serverCapabilities && _serverCapabilities.protocolVersion) || '2024-11-05'
    });
  } catch (e) {
    ok({ status: 'error', error: e.message, url: FASTMAIL_URL });
    process.exit(1);
  }
}

function cmdHelp() {
  console.log('fastmail-axi <command> [options]');
  console.log('');
  console.log('Email commands:');
  console.log('  inbox [--limit N]                        Get recent emails');
  console.log('  search <query> [--limit N]                Search emails');
  console.log('  get <email-id>                            Get full email details');
  console.log('  send <to> <subject> <body> [--cc addr] [--bcc addr]  Send email');
  console.log('  reply <email-id> <body> [--all]           Reply to email');
  console.log('  delete <email-id> [--yes]                 Delete email (--yes skips confirm)');
  console.log('  move <email-id> <mailbox>                 Move email to mailbox');
  console.log('  thread <thread-id>                        Get thread messages');
  console.log('  draft <to> <subject> <body> [--cc addr]   Create draft');
  console.log('  send-draft <draft-id>                     Send a draft');
  console.log('');
  console.log('Contact commands:');
  console.log('  contacts <query>                          Search contacts');
  console.log('  contact <contact-id>                      Get contact details');
  console.log('');
  console.log('Calendar commands:');
  console.log('  calendar [--from date] [--to date]        List calendar events');
  console.log('  event <event-id>                          Get event details');
  console.log('  create-event <title> <start> [--end date] [--location loc]  Create event');
  console.log('  delete-event <event-id> [--yes]           Delete event');
  console.log('');
  console.log('Mailbox commands:');
  console.log('  mailboxes                                 List all mailboxes');
  console.log('  mailbox <name>                            Get mailbox stats');
  console.log('  create-mailbox <name> [--parent name]     Create a new mailbox');
  console.log('');
  console.log('Label commands:');
  console.log('  labels list <email-id>                    List labels on an email');
  console.log('  labels add <email-id> <label...>          Add labels to an email');
  console.log('  labels remove <email-id> <label...>       Remove labels from an email');
  console.log('');
  console.log('Bulk commands:');
  console.log('  bulk delete <mailbox> [--ids a,b,c] [--query q] [--yes]');
  console.log('  bulk read <mailbox> [--ids a,b,c] [--query q]');
  console.log('  bulk move <mailbox> <target> [--ids a,b,c] [--query q]');
  console.log('  bulk pin <mailbox> [--ids a,b,c] [--query q]');
  console.log('');
  console.log('Other:');
  console.log('  advanced-search <jmap-query-json>         Advanced JMAP query');
  console.log('  account                                   Account summary');
  console.log('  identities                                List email identities');
  console.log('  status                                    Server health check');
  console.log('  call <tool-name> --json \'{"k":"v"}\'        Call any MCP tool directly');
  console.log('  call <tool-name> --key val --key2 val2     Call with key=value args');
  console.log('');
  console.log('Env: FASTMAIL_AXI_URL (default: http://localhost:8001)');
}

// ── CLI routing ─────────────────────────────────────

var args = process.argv.slice(2);
var cmd = args[0];

if (!cmd || cmd === '--help' || cmd === '-h') {
  cmdHelp();
  process.exit(0);
}

if (cmd === 'help') {
  if (args[1]) {
    // Show help for specific command
    console.log('help for: ' + args[1]);
    console.log('  Run fastmail-axi --help for full usage.');
    process.exit(0);
  }
  cmdHelp();
  process.exit(0);
}

(async function main() {
  try {
    switch (cmd) {
      case 'inbox':
        await cmdInbox(args);
        break;
      case 'search':
        await cmdSearch(args);
        break;
      case 'get':
        await cmdGet(args);
        break;
      case 'send':
        await cmdSend(args);
        break;
      case 'contacts':
        await cmdContacts(args);
        break;
      case 'contact':
        await cmdContact(args);
        break;
      case 'calendar':
        await cmdCalendar(args);
        break;
      case 'event':
        await cmdEvent(args);
        break;
      case 'create-event':
        await cmdCreateEvent(args);
        break;
      case 'delete-event':
        await cmdDeleteEvent(args);
        break;
      case 'mailboxes':
        await cmdMailboxes(args);
        break;
      case 'mailbox':
        await cmdMailbox(args);
        break;
      case 'create-mailbox':
        await cmdCreateMailbox(args);
        break;
      case 'draft':
        await cmdDraft(args);
        break;
      case 'send-draft':
        await cmdSendDraft(args);
        break;
      case 'delete':
        await cmdDelete(args);
        break;
      case 'move':
        await cmdMove(args);
        break;
      case 'thread':
        await cmdThread(args);
        break;
      case 'reply':
        await cmdReply(args);
        break;
      case 'account':
        await cmdAccount(args);
        break;
      case 'identities':
        await cmdIdentities(args);
        break;
      case 'labels':
        await cmdLabels(args);
        break;
      case 'bulk':
        await cmdBulk(args);
        break;
      case 'advanced-search':
        await cmdAdvancedSearch(args);
        break;
      case 'status':
        await cmdStatus(args);
        break;
      case 'call':
        await cmdCall(args);
        break;
      default:
        die('unknown command: ' + cmd + ' (use --help to see all commands)');
    }
  } catch (e) {
    die(e.message || String(e));
  }
})();
