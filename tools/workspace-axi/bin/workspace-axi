// ── Utility ─────────────────────────────────────────

function extractList(result, tryKeys) {
  if (Array.isArray(result)) return result;
  for (var i = 0; i < tryKeys.length; i++) {
    var val = result[tryKeys[i]];
    if (Array.isArray(val)) return val;
  }
  return [];
}

// ── CLI routing ─────────────────────────────────────

var args = process.argv.slice(2);
var cmd = args[0];

if (!cmd || cmd === '--help' || cmd === '-h') {
  cmdHelp();
  process.exit(0);
}

if (cmd === 'help') {
  cmdHelp();
  process.exit(0);
}

// Build a dispatch table for category:action
var commandDispatch = {
  'gmail:list':     cmdGmailList,
  'gmail:search':   cmdGmailSearch,
  'gmail:get':      cmdGmailGet,
  'gmail:send':     cmdGmailSend,
  'gmail:draft':    cmdGmailDraft,
  'gmail:labels':   cmdGmailLabels,
  'drive:list':     cmdDriveList,
  'drive:get':      cmdDriveGet,
  'drive:search':   cmdDriveSearch,
  'drive:download': cmdDriveDownload,
  'drive:create':   cmdDriveCreate,
  'calendar:list':   cmdCalendarList,
  'calendar:get':    cmdCalendarGet,
  'calendar:create': cmdCalendarCreate,
  'calendar:delete': cmdCalendarDelete,
  'docs:get':       cmdDocsGet,
  'docs:create':    cmdDocsCreate,
  'contacts:search': cmdContactsSearch,
  'contacts:get':    cmdContactsGet,
  'tasks:list':     cmdTasksList,
  'tasks:create':   cmdTasksCreate,
  'status':         cmdStatus,
  'call':           cmdCall,
  'help':           function() { cmdHelp(); }
};

(async function main() {
  try {
    // Single-word commands
    if (cmd === 'status') {
      await cmdStatus(args);
      return;
    }
    if (cmd === 'call') {
      await cmdCall(args);
      return;
    }
    if (cmd === 'help') {
      cmdHelp();
      return;
    }

    // Two-word commands: "category action"
    var action = args[1];
    var dispatchKey = cmd + ':' + action;
    var handler = commandDispatch[dispatchKey];

    if (handler) {
      await handler(args);
    } else {
      // Try listing available actions for this category
      var suggestions = [];
      var dispatchKeys = Object.keys(commandDispatch);
      for (var i = 0; i < dispatchKeys.length; i++) {
        if (dispatchKeys[i].startsWith(cmd + ':')) {
          suggestions.push('  workspace-axi ' + dispatchKeys[i].replace(':', ' '));
        }
      }
      if (suggestions.length > 0) {
        die('unknown subcommand: ' + action + ' for ' + cmd + '. Available:\n' + suggestions.join('\n'));
      } else {
        die('unknown command: ' + cmd + ' (use --help to see all commands)');
      }
    }
  } catch (e) {
    die(e.message || String(e));
  }
})();
