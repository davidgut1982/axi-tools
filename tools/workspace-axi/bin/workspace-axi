// ── Status ──────────────────────────────────────────

async function cmdStatus(args) {
  try {
    await ensureInitialized();
    var toolCount = _toolSchemas ? Object.keys(_toolSchemas).length : 0;
    var mappedCount = _toolMap ? Object.keys(_toolMap).length : 0;

    console.log('ok: true');
    console.log(toon({
      status: 'connected',
      url: WORKSPACE_URL,
      protocolVersion: (_serverCapabilities && _serverCapabilities.protocolVersion) || '2024-11-05',
      serverName: (_serverCapabilities && _serverCapabilities.serverInfo && _serverCapabilities.serverInfo.name) || 'unknown',
      tools: toolCount,
      mapped: mappedCount
    }));

    // Show discovered tools
    if (_toolSchemas && toolCount > 0) {
      console.log('\ntools[' + toolCount + ']{name,description}:');
      var names = Object.keys(_toolSchemas).sort();
      for (var i = 0; i < names.length; i++) {
        var n = names[i];
        var d = _toolSchemas[n].description || '';
        console.log('  ' + n + ',' + truncate(d, 60));
      }
    }

    // Show command mapping
    if (_toolMap && mappedCount > 0) {
      console.log('\ncommands[' + mappedCount + ']{key,tool}:');
      var keys = Object.keys(_toolMap).sort();
      for (var k = 0; k < keys.length; k++) {
        console.log('  ' + keys[k] + ' → ' + _toolMap[keys[k]]);
      }
    }
  } catch (e) {
    ok({ status: 'error', error: e.message, url: WORKSPACE_URL });
    process.exit(1);
  }
}

// ── Call (passthrough) ──────────────────────────────

async function cmdCall(args) {
  var toolName = requireArg(args, 1, 'tool name');
  var params = parseJsonArg(args);

  if (!params) {
    params = {};
    for (var i = 2; i < args.length; i++) {
      if (args[i].startsWith('--')) {
        var key = args[i].slice(2);
        if (i + 1 < args.length && !args[i + 1].startsWith('--')) {
          params[key] = args[i + 1];
          i++;
        } else {
          params[key] = true;
        }
      }
    }
  }

  var result = await mcpCallTool(toolName, params);
  ok(result);
}

