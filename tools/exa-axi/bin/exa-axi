#!/usr/bin/env node
// exa-axi — Exa AI-powered web search via direct HTTPS API
// Zero dependencies. TOON output. Agent-friendly.
// Docs: https://docs.exa.ai/reference/search

const https = require('https');

// ── Configuration ───────────────────────────────────

const API_KEY = process.env.EXA_AXI_API_KEY || process.env.EXA_API_KEY || '';
const API_HOST = 'api.exa.ai';
const TIMEOUT_MS = 30000;

// ── HTTPS request helper ─────────────────────────────

function httpsRequest(method, path, headers, body) {
  return new Promise(function(resolve, reject) {
    var options = {
      hostname: API_HOST,
      port: 443,
      path: path,
      method: method,
      headers: headers || {},
      timeout: TIMEOUT_MS
    };

    if (body) {
      var payload = JSON.stringify(body);
      options.headers['Content-Type'] = 'application/json';
      options.headers['Content-Length'] = Buffer.byteLength(payload);
    }

    var req = https.request(options, function(res) {
      var chunks = [];
      res.on('data', function(c) { chunks.push(c); });
      res.on('end', function() {
        var raw = Buffer.concat(chunks).toString('utf8');
        var data;
        try { data = JSON.parse(raw); } catch (_) { data = raw; }

        if (res.statusCode >= 400) {
          var msg = typeof data === 'object' && data.error ? data.error : raw.slice(0, 300);
          reject(new Error('HTTP ' + res.statusCode + ': ' + msg));
          return;
        }

        resolve(data);
      });
      res.on('error', reject);
    });

    req.on('error', reject);
    req.on('timeout', function() {
      req.destroy();
      reject(new Error('request timeout after ' + (TIMEOUT_MS / 1000) + 's'));
    });

    if (body) req.write(payload);
    req.end();
  });
}

// ── TOON formatter ──────────────────────────────────

function toon(obj) {
  function val(v, indent) {
    indent = indent || 0;
    var pad = '';
    for (var i = 0; i < indent; i++) pad += '  ';
    if (v === null || v === undefined) return 'null';
    if (typeof v === 'boolean' || typeof v === 'number') return String(v);
    if (typeof v === 'string') {
      var special = /[:#!$%&*?|<>;@`\n\r\t"'\[\]{},]|^\s|\s$/;
      if (special.test(v) || v === '') return JSON.stringify(v);
      return v;
    }
    if (Array.isArray(v)) {
      if (v.length === 0) return '[]';
      var lines = [];
      for (var j = 0; j < v.length; j++) {
        var item = v[j];
        if (typeof item === 'object' && item !== null && !Array.isArray(item)) {
          var inner = val(item, indent + 1);
          inner = inner.replace(/^\n/, '');
          lines.push(pad + '  - ' + inner);
        } else {
          lines.push(pad + '  - ' + val(item, indent + 1));
        }
      }
      return '[' + v.length + ']\n' + lines.join('\n');
    }
    if (typeof v === 'object') {
      var keys = Object.keys(v);
      if (keys.length === 0) return '{}';
      var lines2 = [];
      for (var k = 0; k < keys.length; k++) {
        var key = keys[k];
        var vv = val(v[key], indent + 1);
        if (vv.indexOf('\n') !== -1) {
          lines2.push(pad + '  ' + key + ':');
          var innerLines = vv.split('\n');
          for (var li = 0; li < innerLines.length; li++) {
            var ln = innerLines[li];
            if (ln.trim()) lines2.push(pad + '    ' + ln.trimStart());
          }
        } else {
          lines2.push(pad + '  ' + key + ': ' + vv);
        }
      }
      return '\n' + lines2.join('\n');
    }
    return String(v);
  }
  return val(obj).replace(/^\n/, '').trim();
}

function die(msg) {
  console.log(toon({ ok: false, error: msg }));
  process.exit(1);
}

function okOut(dataObj) {
  console.log(toon({ ok: true, data: dataObj }));
}

// ── CLI helpers ─────────────────────────────────────

function flagVal(args, flag) {
  var idx = args.indexOf(flag);
  return idx !== -1 && idx + 1 < args.length ? args[idx + 1] : null;
}

function hasFlag(args, flag) {
  return args.indexOf(flag) !== -1;
}

function requireArg(args, idx, name) {
  if (idx >= args.length || args[idx].startsWith('-')) {
    die('missing ' + name);
  }
  return args[idx];
}

// ── Commands ────────────────────────────────────────

async function cmdSearch(args) {
  var query = requireArg(args, 1, 'search query');
  var limit = parseInt(flagVal(args, '--limit') || '10', 10);
  var type = flagVal(args, '--type') || 'auto';

  if (['auto', 'text', 'url'].indexOf(type) === -1) {
    die('invalid --type: ' + type + ' (use auto, text, or url)');
  }

  var body = {
    query: query,
    numResults: limit,
    type: type,
    useAutoprompt: true
  };

  var result = await httpsRequest('POST', '/search', {
    'x-api-key': API_KEY,
    'Content-Type': 'application/json'
  }, body);

  var results = result.results || [];
  if (!Array.isArray(results)) results = [];

  console.log('ok: true');
  console.log('search[' + results.length + ']{title,url,publishedDate}:');
  for (var i = 0; i < results.length; i++) {
    var r = results[i];
    console.log('  ' + [
      (r.title || '(no title)'),
      (r.url || '?'),
      (r.publishedDate || r.date || '?')
    ].join(' | '));
  }

  if (results.length > 0) {
    console.log('help[' + Math.min(3, results.length) + ']:');
    console.log('  ' + results.map(function(r) { return r.url; }).join('\n  '));
  }
}

async function cmdSimilar(args) {
  var url = requireArg(args, 1, 'URL to find similar pages');
  var limit = parseInt(flagVal(args, '--limit') || '10', 10);

  var body = {
    query: url,
    numResults: limit,
    type: 'similar',
    useAutoprompt: true
  };

  // Exa supports similar via the search endpoint with type=similar
  // Also has dedicated /similar endpoint
  var result;
  try {
    result = await httpsRequest('POST', '/similar', {
      'x-api-key': API_KEY,
      'Content-Type': 'application/json'
    }, { url: url, numResults: limit });
  } catch (e) {
    // Fallback: use search endpoint with URL as query + type=similar
    result = await httpsRequest('POST', '/search', {
      'x-api-key': API_KEY,
      'Content-Type': 'application/json'
    }, body);
  }

  var results = result.results || [];
  if (!Array.isArray(results)) results = [];

  console.log('ok: true');
  console.log('similar[' + results.length + ']{title,url,score}:');
  for (var i = 0; i < results.length; i++) {
    var r = results[i];
    console.log('  ' + [
      (r.title || '(no title)'),
      (r.url || '?'),
      (r.score != null ? r.score.toFixed(3) : '?')
    ].join(' | '));
  }
}

async function cmdStatus() {
  var start = Date.now();
  try {
    // Test with a minimal request
    var result = await httpsRequest('POST', '/search', {
      'x-api-key': API_KEY,
      'Content-Type': 'application/json'
    }, { query: 'test', numResults: 1, type: 'auto', useAutoprompt: true });

    var elapsed = Date.now() - start;
    var count = (result.results && result.results.length) || 0;

    okOut({
      status: 'ok',
      latency_ms: elapsed,
      results_returned: count,
      api: 'https://api.exa.ai/search',
      key_configured: API_KEY ? 'yes' : 'no'
    });
  } catch (e) {
    okOut({ status: 'error', error: e.message, api: 'https://api.exa.ai/search' });
    process.exit(1);
  }
}

function cmdHelp() {
  console.log('exa-axi <command> [options]');
  console.log('');
  console.log('Commands:');
  console.log('  search <query> [--limit N] [--type auto|text|url]');
  console.log('      AI-powered web search via Exa API');
  console.log('');
  console.log('  similar <url> [--limit N]');
  console.log('      Find pages similar to a URL');
  console.log('');
  console.log('  status');
  console.log('      API connectivity check');
  console.log('');
  console.log('  help');
  console.log('      Show this help');
  console.log('');
  console.log('Env:');
  console.log('  EXA_AXI_API_KEY   Exa API key (required)');
  console.log('  EXA_API_KEY       Fallback API key');
  console.log('');
  console.log('Get an API key: https://exa.ai');
}

// ── Main ────────────────────────────────────────────

var args = process.argv.slice(2);
var cmd = args[0];

if (!cmd || cmd === '--help' || cmd === '-h' || cmd === 'help') {
  cmdHelp();
  process.exit(0);
}

if (!API_KEY && cmd !== 'help') {
  die('EXA_AXI_API_KEY not set. Get a key at https://exa.ai');
}

(async function main() {
  try {
    switch (cmd) {
      case 'search':
        await cmdSearch(args);
        break;
      case 'similar':
        await cmdSimilar(args);
        break;
      case 'status':
        await cmdStatus();
        break;
      default:
        die('unknown command: ' + cmd + ' (use --help to see all commands)');
    }
  } catch (e) {
    die(e.message || String(e));
  }
})();
