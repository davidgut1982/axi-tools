#!/usr/bin/env node
// weather-axi — Weather via direct HTTPS API (OpenMeteo + NOAA)
// Zero dependencies. TOON output. Agent-friendly.
// OpenMeteo: free, no API key. NOAA: free, no API key, US-only.

const https = require('https');

// ── Configuration ───────────────────────────────────

const UNITS = process.env.WEATHER_AXI_UNITS || 'metric';
// NOAA alerts are US-only
// OpenMeteo is global, free, no key

const TIMEOUT_MS = 30000;

// WMO weather code → description
var WMO_CODES = {
  0: 'Clear sky', 1: 'Mainly clear', 2: 'Partly cloudy', 3: 'Overcast',
  45: 'Fog', 48: 'Depositing rime fog',
  51: 'Light drizzle', 53: 'Moderate drizzle', 55: 'Dense drizzle',
  56: 'Light freezing drizzle', 57: 'Dense freezing drizzle',
  61: 'Slight rain', 63: 'Moderate rain', 65: 'Heavy rain',
  66: 'Light freezing rain', 67: 'Heavy freezing rain',
  71: 'Slight snow', 73: 'Moderate snow', 75: 'Heavy snow',
  77: 'Snow grains',
  80: 'Slight rain showers', 81: 'Moderate rain showers', 82: 'Violent rain showers',
  85: 'Slight snow showers', 86: 'Heavy snow showers',
  95: 'Thunderstorm', 96: 'Thunderstorm + slight hail', 99: 'Thunderstorm + heavy hail'
};

// European AQI → description (continuous index)
function euAqiDesc(val) {
  if (val == null) return '?';
  if (val <= 20) return 'Good';
  if (val <= 40) return 'Fair';
  if (val <= 60) return 'Moderate';
  if (val <= 80) return 'Poor';
  if (val <= 100) return 'Very Poor';
  return 'Extremely Poor';
}

// US AQI → description
function usAqiDesc(val) {
  if (val == null) return '?';
  if (val <= 50) return 'Good';
  if (val <= 100) return 'Moderate';
  if (val <= 150) return 'Unhealthy for Sensitive';
  if (val <= 200) return 'Unhealthy';
  if (val <= 300) return 'Very Unhealthy';
  return 'Hazardous';
}

// ── Generic HTTPS GET ───────────────────────────────

function httpsGet(hostname, path) {
  return new Promise(function(resolve, reject) {
    var options = {
      hostname: hostname,
      port: 443,
      path: path,
      method: 'GET',
      headers: { 'Accept': 'application/json', 'User-Agent': 'weather-axi/1.0' },
      timeout: TIMEOUT_MS
    };

    var req = https.request(options, function(res) {
      // Handle redirects
      if (res.statusCode >= 300 && res.statusCode < 400 && res.headers.location) {
        var loc = res.headers.location;
        var redirHost, redirPath;
        if (loc.startsWith('https://')) {
          var u = new (require('url').URL)(loc);
          redirHost = u.hostname;
          redirPath = u.pathname + (u.search || '');
        } else {
          redirHost = hostname;
          redirPath = loc;
        }
        httpsGet(redirHost, redirPath).then(resolve, reject);
        return;
      }

      var chunks = [];
      res.on('data', function(c) { chunks.push(c); });
      res.on('end', function() {
        var raw = Buffer.concat(chunks).toString('utf8');
        var data;
        try { data = JSON.parse(raw); } catch (_) { data = raw; }

        if (res.statusCode >= 400) {
          var msg = (typeof data === 'object' && (data.title || data.detail)) || raw.slice(0, 300);
          reject(new Error('HTTP ' + res.statusCode + ': ' + msg));
          return;
        }

        resolve(data);
      });
      res.on('error', reject);
    });

    req.on('error', reject);
    req.on('timeout', function() {
      req.destroy();
      reject(new Error('request timeout after ' + (TIMEOUT_MS / 1000) + 's'));
    });
    req.end();
  });
}

// ── TOON formatter ──────────────────────────────────

function toon(obj) {
  function val(v, indent) {
    indent = indent || 0;
    var pad = '';
    for (var i = 0; i < indent; i++) pad += '  ';
    if (v === null || v === undefined) return 'null';
    if (typeof v === 'boolean' || typeof v === 'number') return String(v);
    if (typeof v === 'string') {
      var special = /[:#!$%&*?|<>;@`\n\r\t"'\[\]{},]|^\s|\s$/;
      if (special.test(v) || v === '') return JSON.stringify(v);
      return v;
    }
    if (Array.isArray(v)) {
      if (v.length === 0) return '[]';
      var lines = [];
      for (var j = 0; j < v.length; j++) {
        var item = v[j];
        if (typeof item === 'object' && item !== null && !Array.isArray(item)) {
          var inner = val(item, indent + 1);
          inner = inner.replace(/^\n/, '');
          lines.push(pad + '  - ' + inner);
        } else {
          lines.push(pad + '  - ' + val(item, indent + 1));
        }
      }
      return '[' + v.length + ']\n' + lines.join('\n');
    }
    if (typeof v === 'object') {
      var keys = Object.keys(v);
      if (keys.length === 0) return '{}';
      var lines2 = [];
      for (var k = 0; k < keys.length; k++) {
        var key = keys[k];
        var vv = val(v[key], indent + 1);
        if (vv.indexOf('\n') !== -1) {
          lines2.push(pad + '  ' + key + ':');
          var innerLines = vv.split('\n');
          for (var li = 0; li < innerLines.length; li++) {
            var ln = innerLines[li];
            if (ln.trim()) lines2.push(pad + '    ' + ln.trimStart());
          }
        } else {
          lines2.push(pad + '  ' + key + ': ' + vv);
        }
      }
      return '\n' + lines2.join('\n');
    }
    return String(v);
  }
  return val(obj).replace(/^\n/, '').trim();
}

function die(msg) {
  console.log(toon({ ok: false, error: msg }));
  process.exit(1);
}

function okOut(dataObj) {
  console.log(toon({ ok: true, data: dataObj }));
}

// ── CLI helpers ─────────────────────────────────────

function flagVal(args, flag) {
  var idx = args.indexOf(flag);
  return idx !== -1 && idx + 1 < args.length ? args[idx + 1] : null;
}

function requireArg(args, idx, name) {
  if (idx >= args.length) {
    die('missing ' + name);
  }
  var arg = args[idx];
  // Allow negative numbers (e.g. -74.01) as positional args
  if (arg.startsWith('-') && isNaN(parseFloat(arg))) {
    die('missing ' + name);
  }
  return arg;
}

// ── Geocoding ───────────────────────────────────────

async function geocode(city) {
  var data = await httpsGet('geocoding-api.open-meteo.com',
    '/v1/search?name=' + encodeURIComponent(city) + '&count=1&language=en');

  if (!data.results || data.results.length === 0) {
    die('city not found: ' + city);
  }

  var r = data.results[0];
  return {
    name: r.name,
    country: r.country || '?',
    state: r.admin1 || '',
    lat: r.latitude,
    lon: r.longitude,
    timezone: r.timezone || 'auto',
    display: (r.name || city) + (r.admin1 ? ', ' + r.admin1 : '') + (r.country ? ', ' + r.country : '')
  };
}

// ── WMO weather code helper ─────────────────────────

function weatherDesc(code) {
  if (code === null || code === undefined) return '?';
  return WMO_CODES[code] || ('Code ' + code);
}

// ── Commands ────────────────────────────────────────

async function cmdLocate(args) {
  var city = requireArg(args, 1, 'city name');
  var loc = await geocode(city);
  okOut(loc);
}

async function cmdCurrent(args) {
  // parse location: could be "city name" or "lat lon"
  var locStr = requireArg(args, 1, 'location (city name or lat lon)');
  var lat, lon;

  if (/^-?[\d.]+$/.test(locStr)) {
    // it's a lat, need a lon as second arg
    lat = parseFloat(locStr);
    lon = parseFloat(requireArg(args, 2, 'longitude'));
  } else if (args.length >= 2 && /^-?[\d.]+$/.test(args[1]) && /^-?[\d.]+$/.test(args[2])) {
    lat = parseFloat(args[1]);
    lon = parseFloat(args[2]);
  } else {
    var loc = await geocode(locStr);
    lat = loc.lat;
    lon = loc.lon;
  }

  var data = await httpsGet('api.open-meteo.com',
    '/v1/forecast?latitude=' + lat + '&longitude=' + lon +
    '&current=temperature_2m,relative_humidity_2m,wind_speed_10m,weather_code' +
    '&timezone=auto&forecast_days=1');

  var c = data.current || {};
  okOut({
    location: { lat: lat, lon: lon },
    time: c.time || '?',
    temperature: c.temperature_2m != null ? c.temperature_2m + '°' + (UNITS === 'imperial' ? 'F' : 'C') : '?',
    humidity: c.relative_humidity_2m != null ? c.relative_humidity_2m + '%' : '?',
    wind: c.wind_speed_10m != null ? c.wind_speed_10m + ' km/h' : '?',
    conditions: weatherDesc(c.weather_code)
  });
}

async function cmdForecast(args) {
  var locStr = requireArg(args, 1, 'location (city name or lat lon)');
  var days = parseInt(flagVal(args, '--days') || '7', 10);
  if (days < 1 || days > 16) die('--days must be 1-16');

  var lat, lon, locDisplay;

  if (/^-?[\d.]+$/.test(locStr)) {
    lat = parseFloat(locStr);
    lon = parseFloat(requireArg(args, 2, 'longitude'));
    locDisplay = lat + ', ' + lon;
  } else if (args.length >= 2 && /^-?[\d.]+$/.test(args[1]) && /^-?[\d.]+$/.test(args[2])) {
    lat = parseFloat(args[1]);
    lon = parseFloat(args[2]);
    locDisplay = lat + ', ' + lon;
  } else {
    var loc = await geocode(locStr);
    lat = loc.lat;
    lon = loc.lon;
    locDisplay = loc.display;
  }

  var data = await httpsGet('api.open-meteo.com',
    '/v1/forecast?latitude=' + lat + '&longitude=' + lon +
    '&daily=temperature_2m_max,temperature_2m_min,precipitation_sum,weathercode' +
    '&current=temperature_2m,relative_humidity_2m,wind_speed_10m,weather_code' +
    '&forecast_days=' + days + '&timezone=auto');

  var c = data.current || {};
  var d = data.daily || {};
  var dates = d.time || [];

  console.log('ok: true');
  console.log('location: ' + locDisplay);
  console.log('units: ' + (UNITS === 'imperial' ? '°F' : '°C'));
  console.log('');
  console.log('now: ' + (c.temperature_2m != null ? c.temperature_2m + '°' : '?') +
    ' | ' + (c.relative_humidity_2m != null ? c.relative_humidity_2m + '%' : '?') +
    ' | wind ' + (c.wind_speed_10m != null ? c.wind_speed_10m + ' km/h' : '?') +
    ' | ' + weatherDesc(c.weather_code));
  console.log('');
  console.log('forecast[' + dates.length + ']{date,high,low,precip,conditions}:');

  for (var i = 0; i < dates.length; i++) {
    var hi = d.temperature_2m_max ? d.temperature_2m_max[i] : '?';
    var lo = d.temperature_2m_min ? d.temperature_2m_min[i] : '?';
    var precip = d.precipitation_sum ? d.precipitation_sum[i] : '?';
    var code = d.weathercode ? d.weathercode[i] : null;

    var line = dates[i] + ' | ';
    line += 'Hi: ' + (hi !== '?' ? hi + '°' : '?') + ' | ';
    line += 'Lo: ' + (lo !== '?' ? lo + '°' : '?') + ' | ';
    line += 'Rain: ' + (precip !== '?' ? precip + 'mm' : '?') + ' | ';
    line += weatherDesc(code);
    console.log('  ' + line);
  }
}

async function cmdAlerts(args) {
  var state = requireArg(args, 1, 'US state code (e.g. TX, CA, NY)').toUpperCase();

  if (state.length !== 2) {
    die('state must be a 2-letter US state code (e.g. TX, CA, NY)');
  }

  var data = await httpsGet('api.weather.gov',
    '/alerts/active?area=' + encodeURIComponent(state));

  var features = data.features || [];
  console.log('ok: true');
  console.log('alerts[' + features.length + ']{event,severity,headline}:');
  for (var i = 0; i < features.length; i++) {
    var props = features[i].properties || {};
    var f = features[i];
    console.log('  - event: ' + (props.event || '?'));
    console.log('    severity: ' + (props.severity || '?'));
    console.log('    headline: ' + (props.headline || '?').replace(/\n/g, ' '));
    console.log('    area: ' + (props.areaDesc || '?'));
    if (props.effective) console.log('    effective: ' + props.effective);
    if (props.expires) console.log('    expires: ' + props.expires);
    console.log('');
  }
}

async function cmdAirQuality(args) {
  var lat = parseFloat(requireArg(args, 1, 'latitude'));
  var lon = parseFloat(requireArg(args, 2, 'longitude'));

  if (isNaN(lat) || isNaN(lon)) die('latitude and longitude must be numbers');

  var data = await httpsGet('air-quality-api.open-meteo.com',
    '/v1/air-quality?latitude=' + lat + '&longitude=' + lon +
    '&current=european_aqi,us_aqi,pm10,pm2_5');

  var c = data.current || {};
  var europeanAQI = c.european_aqi != null ? c.european_aqi : null;
  var usAQI = c.us_aqi != null ? c.us_aqi : null;

  console.log('ok: true');
  console.log('location: ' + lat + ', ' + lon);
  console.log('time: ' + (c.time || '?'));
  console.log('');
  console.log('pm2.5: ' + (c.pm2_5 != null ? c.pm2_5 + ' µg/m³' : '?'));
  console.log('pm10: ' + (c.pm10 != null ? c.pm10 + ' µg/m³' : '?'));
  console.log('EU AQI: ' + (europeanAQI != null ? europeanAQI + ' (' + euAqiDesc(europeanAQI) + ')' : '?'));
  console.log('US AQI: ' + (usAQI != null ? usAQI + ' (' + usAqiDesc(usAQI) + ')' : '?'));
}

async function cmdStatus() {
  var start = Date.now();
  try {
    var data = await httpsGet('api.open-meteo.com',
      '/v1/forecast?latitude=51.5&longitude=-0.12&current=temperature_2m&forecast_days=1');

    var elapsed = Date.now() - start;
    okOut({
      status: 'ok',
      latency_ms: elapsed,
      api: 'https://api.open-meteo.com',
      weather_service: 'OpenMeteo (free, no key required)',
      alerts_service: 'NOAA weather.gov (free, US-only)'
    });
  } catch (e) {
    okOut({ status: 'error', error: e.message, api: 'https://api.open-meteo.com' });
    process.exit(1);
  }
}

function cmdHelp() {
  console.log('weather-axi <command> [options]');
  console.log('');
  console.log('Commands:');
  console.log('  forecast <location> [--days N]');
  console.log('      7-day weather forecast (N=1-16). Location: "New York" or "34.05 -118.24"');
  console.log('');
  console.log('  current <location>');
  console.log('      Current weather conditions');
  console.log('');
  console.log('  alerts <state>');
  console.log('      Active NOAA weather alerts for a US state (e.g. TX, CA, NY)');
  console.log('');
  console.log('  air-quality <lat> <lon>');
  console.log('      Current air quality (European AQI, US AQI, PM2.5, PM10)');
  console.log('');
  console.log('  locate <city>');
  console.log('      Geocode a city name to lat/lon coordinates');
  console.log('');
  console.log('  status');
  console.log('      API connectivity check');
  console.log('');
  console.log('  help');
  console.log('      Show this help');
  console.log('');
  console.log('Env:');
  console.log('  WEATHER_AXI_UNITS   Units: metric (default) or imperial');
  console.log('');
  console.log('Powered by OpenMeteo (free, no key) and NOAA (free, US-only alerts)');
}

// ── Main ────────────────────────────────────────────

var args = process.argv.slice(2);
var cmd = args[0];

if (!cmd || cmd === '--help' || cmd === '-h' || cmd === 'help') {
  cmdHelp();
  process.exit(0);
}

(async function main() {
  try {
    switch (cmd) {
      case 'forecast':
        await cmdForecast(args);
        break;
      case 'current':
        await cmdCurrent(args);
        break;
      case 'alerts':
        await cmdAlerts(args);
        break;
      case 'air-quality':
        await cmdAirQuality(args);
        break;
      case 'locate':
        await cmdLocate(args);
        break;
      case 'status':
        await cmdStatus();
        break;
      default:
        die('unknown command: ' + cmd + ' (use --help to see all commands)');
    }
  } catch (e) {
    die(e.message || String(e));
  }
})();
