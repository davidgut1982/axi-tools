#!/usr/bin/env node
// tavily-axi — Tavily real-time web search via direct HTTPS API
// Zero dependencies. TOON output. Agent-friendly.
// Docs: https://docs.tavily.com/api-reference/endpoint/search

const https = require('https');

// ── Configuration ───────────────────────────────────

const API_KEY = process.env.TAVILY_AXI_API_KEY || process.env.TAVILY_API_KEY || '';
const API_HOST = 'api.tavily.com';
const TIMEOUT_MS = 30000;

// ── HTTPS request helper ─────────────────────────────

function httpsRequest(method, path, body) {
  return new Promise(function(resolve, reject) {
    var payload = body ? JSON.stringify(body) : null;

    var options = {
      hostname: API_HOST,
      port: 443,
      path: path,
      method: method,
      headers: {
        'Content-Type': 'application/json'
      },
      timeout: TIMEOUT_MS
    };

    if (payload) {
      options.headers['Content-Length'] = Buffer.byteLength(payload);
    }

    var req = https.request(options, function(res) {
      var chunks = [];
      res.on('data', function(c) { chunks.push(c); });
      res.on('end', function() {
        var raw = Buffer.concat(chunks).toString('utf8');
        var data;
        try { data = JSON.parse(raw); } catch (_) { data = raw; }

        if (res.statusCode >= 400) {
          var msg = typeof data === 'object' && data.error ? data.error : raw.slice(0, 300);
          reject(new Error('HTTP ' + res.statusCode + ': ' + msg));
          return;
        }

        resolve(data);
      });
      res.on('error', reject);
    });

    req.on('error', reject);
    req.on('timeout', function() {
      req.destroy();
      reject(new Error('request timeout after ' + (TIMEOUT_MS / 1000) + 's'));
    });

    if (payload) req.write(payload);
    req.end();
  });
}

// ── TOON formatter ──────────────────────────────────

function toon(obj) {
  function val(v, indent) {
    indent = indent || 0;
    var pad = '';
    for (var i = 0; i < indent; i++) pad += '  ';
    if (v === null || v === undefined) return 'null';
    if (typeof v === 'boolean' || typeof v === 'number') return String(v);
    if (typeof v === 'string') {
      var special = /[:#!$%&*?|<>;@`\n\r\t"'\[\]{},]|^\s|\s$/;
      if (special.test(v) || v === '') return JSON.stringify(v);
      return v;
    }
    if (Array.isArray(v)) {
      if (v.length === 0) return '[]';
      var lines = [];
      for (var j = 0; j < v.length; j++) {
        var item = v[j];
        if (typeof item === 'object' && item !== null && !Array.isArray(item)) {
          var inner = val(item, indent + 1);
          inner = inner.replace(/^\n/, '');
          lines.push(pad + '  - ' + inner);
        } else {
          lines.push(pad + '  - ' + val(item, indent + 1));
        }
      }
      return '[' + v.length + ']\n' + lines.join('\n');
    }
    if (typeof v === 'object') {
      var keys = Object.keys(v);
      if (keys.length === 0) return '{}';
      var lines2 = [];
      for (var k = 0; k < keys.length; k++) {
        var key = keys[k];
        var vv = val(v[key], indent + 1);
        if (vv.indexOf('\n') !== -1) {
          lines2.push(pad + '  ' + key + ':');
          var innerLines = vv.split('\n');
          for (var li = 0; li < innerLines.length; li++) {
            var ln = innerLines[li];
            if (ln.trim()) lines2.push(pad + '    ' + ln.trimStart());
          }
        } else {
          lines2.push(pad + '  ' + key + ': ' + vv);
        }
      }
      return '\n' + lines2.join('\n');
    }
    return String(v);
  }
  return val(obj).replace(/^\n/, '').trim();
}

function die(msg) {
  console.log(toon({ ok: false, error: msg }));
  process.exit(1);
}

function okOut(dataObj) {
  console.log(toon({ ok: true, data: dataObj }));
}

// ── CLI helpers ─────────────────────────────────────

function flagVal(args, flag) {
  var idx = args.indexOf(flag);
  return idx !== -1 && idx + 1 < args.length ? args[idx + 1] : null;
}

function hasFlag(args, flag) {
  return args.indexOf(flag) !== -1;
}

function requireArg(args, idx, name) {
  if (idx >= args.length || args[idx].startsWith('-')) {
    die('missing ' + name);
  }
  return args[idx];
}

// ── Result formatter ────────────────────────────────

function formatResult(r) {
  var parts = [
    (r.title || '(no title)'),
    (r.url || '?')
  ];
  if (r.score != null) parts.push(r.score.toFixed(2));
  if (r.published_date || r.date) parts.push(r.published_date || r.date);
  var content = (r.content || '').slice(0, 120).replace(/\n/g, ' ');
  if (content) parts.push(content);
  return parts.join(' | ');
}

// ── Commands ────────────────────────────────────────

async function cmdSearch(args) {
  var query = requireArg(args, 1, 'search query');
  var limit = parseInt(flagVal(args, '--limit') || '10', 10);
  var depth = flagVal(args, '--depth') || 'basic';
  var includeAnswer = hasFlag(args, '--include-answer');

  if (['basic', 'advanced'].indexOf(depth) === -1) {
    die('invalid --depth: ' + depth + ' (use basic or advanced)');
  }

  var body = {
    api_key: API_KEY,
    query: query,
    max_results: limit,
    search_depth: depth,
    include_answer: includeAnswer
  };

  var result = await httpsRequest('POST', '/search', body);

  var results = result.results || [];
  if (!Array.isArray(results)) results = [];

  console.log('ok: true');
  console.log('search[' + results.length + ']{title,url,score,date,content}:');
  for (var i = 0; i < results.length; i++) {
    console.log('  ' + formatResult(results[i]));
  }

  if (result.answer) {
    console.log('\nanswer: ' + toon(result.answer));
  }

  if (results.length > 0) {
    console.log('help[2]:');
    console.log('  tavily-axi search "' + query + '" --limit 20');
    if (result.answer) console.log('  # answer included above');
    console.log('  ' + results[0].url);
  }
}

async function cmdExtract(args) {
  var url = requireArg(args, 1, 'URL to extract');
  var limit = parseInt(flagVal(args, '--limit') || '5', 10);

  var body = {
    api_key: API_KEY,
    urls: [url],
    max_results: limit
  };

  var result = await httpsRequest('POST', '/extract', body);

  var results = result.results || [];
  if (!Array.isArray(results)) results = [];

  console.log('ok: true');
  console.log('extract[' + results.length + ']{url,title}:');
  for (var i = 0; i < results.length; i++) {
    var r = results[i];
    var content = (r.raw_content || r.content || '').slice(0, 200).replace(/\n/g, ' ');
    console.log('  ' + (r.url || url) + ' | ' + (r.title || '?'));
    if (content) console.log('    ' + content);
  }
}

async function cmdStatus() {
  var start = Date.now();
  try {
    var result = await httpsRequest('POST', '/search', {
      api_key: API_KEY,
      query: 'test',
      max_results: 1,
      search_depth: 'basic',
      include_answer: false
    });

    var elapsed = Date.now() - start;
    var count = (result.results && result.results.length) || 0;

    okOut({
      status: 'ok',
      latency_ms: elapsed,
      results_returned: count,
      api: 'https://api.tavily.com/search',
      key_configured: API_KEY ? 'yes' : 'no'
    });
  } catch (e) {
    okOut({ status: 'error', error: e.message, api: 'https://api.tavily.com/search' });
    process.exit(1);
  }
}

function cmdHelp() {
  console.log('tavily-axi <command> [options]');
  console.log('');
  console.log('Commands:');
  console.log('  search <query> [--limit N] [--depth basic|advanced] [--include-answer]');
  console.log('      Real-time web search via Tavily API');
  console.log('');
  console.log('  extract <url> [--limit N]');
  console.log('      Extract content from a URL');
  console.log('');
  console.log('  status');
  console.log('      API connectivity check');
  console.log('');
  console.log('  help');
  console.log('      Show this help');
  console.log('');
  console.log('Env:');
  console.log('  TAVILY_AXI_API_KEY   Tavily API key (required)');
  console.log('  TAVILY_API_KEY       Fallback API key');
  console.log('');
  console.log('Get an API key: https://tavily.com');
}

// ── Main ────────────────────────────────────────────

var args = process.argv.slice(2);
var cmd = args[0];

if (!cmd || cmd === '--help' || cmd === '-h' || cmd === 'help') {
  cmdHelp();
  process.exit(0);
}

if (!API_KEY && cmd !== 'help') {
  die('TAVILY_AXI_API_KEY not set. Get a key at https://tavily.com');
}

(async function main() {
  try {
    switch (cmd) {
      case 'search':
        await cmdSearch(args);
        break;
      case 'extract':
        await cmdExtract(args);
        break;
      case 'status':
        await cmdStatus();
        break;
      default:
        die('unknown command: ' + cmd + ' (use --help to see all commands)');
    }
  } catch (e) {
    die(e.message || String(e));
  }
})();
